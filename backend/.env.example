# ============================================================
# .env.example – Vorlage, NIEMALS echte Werte eintragen!
# Kopieren: cp .env.example .env  (lokal)
# Produktiv: .env.prod auf dem Server anlegen
# ============================================================

# --- Datenbank ---
POSTGRES_USER=insolvenz
POSTGRES_PASSWORD=CHANGEME_min16chars
POSTGRES_DB=insolvenz_db
DATABASE_URL=postgresql+asyncpg://insolvenz:CHANGEME_min16chars@postgres:5432/insolvenz_db

# --- Redis ---
REDIS_PASSWORD=CHANGEME_min16chars
REDIS_URL=redis://:CHANGEME_min16chars@redis:6379/0

# --- MinIO (Dokumentenspeicher) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGEME_min16chars
MINIO_BUCKET=insolvenz-docs

# --- FastAPI / JWT ---
# Generieren: openssl rand -hex 32
SECRET_KEY=CHANGEME_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App-Einstellungen ---
ENVIRONMENT=development   # development | production
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000

# --- E-Mail (für Fristbenachrichtigungen) ---
SMTP_HOST=smtp.example.de
SMTP_PORT=587
SMTP_USER=noreply@example.de
SMTP_PASSWORD=CHANGEME
SMTP_FROM=noreply@example.de

# --- Verschlüsselung (pgcrypto) ---
# Generieren: openssl rand -hex 32
DB_ENCRYPTION_KEY=CHANGEME_generate_with_openssl_rand_hex_32
